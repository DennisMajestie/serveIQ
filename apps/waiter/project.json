{
  "name": "waiter",
  "root": "apps/waiter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/waiter/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/waiter",
        "browser": "apps/waiter/src/main.ts",
        "tsConfig": "apps/waiter/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/waiter/public"
          },
          {
            "glob": "**/*",
            "input": "apps/waiter/src/assets"
          }
        ],
        "styles": ["apps/waiter/src/styles.scss"],
        "fileReplacements": [
          {
            "replace": "apps/waiter/src/environments/environment.ts",
            "with": "apps/waiter/src/environments/environment.prod.ts"
          }
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "12kb",
              "maximumError": "15kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4201
      },
      "configurations": {
        "production": {
          "buildTarget": "waiter:build:production"
        },
        "development": {
          "buildTarget": "waiter:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "waiter:build",
        "port": 4200,
        "staticFilePath": "dist/apps/waiter/browser",
        "spa": true
      }
    }
  }
}
